# Copy this file to .env and add your own keys.
# .env is ignored by git.

# Local server
HOST=127.0.0.1
PORT=8000
DATA_DIR=./data
WORK_DIR=
ALLOW_SAVED_API_KEYS=1

# Free Gemini option
GEMINI_API_KEY=
# Google's Gemini docs also allow GOOGLE_API_KEY.
GOOGLE_API_KEY=

# OpenAI API Key option
OPENAI_API_KEY=

# OpenRouter API Key option
OPENROUTER_API_KEY=

# Optional: override the Codex binary path for OpenAI Login
CODEX_BIN=
